{
  "name": "mymusic-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/tsx/dist/cli.mjs watch src/index.ts",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && node node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node --experimental-specifier-resolution=node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "mongoose": "^8.18.0",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.13.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
